# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- LLM (Anthropic / Claude) ---
# https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- LangSmith (cloud free tier) ---
# https://smith.langchain.com -> Settings -> API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxx
# Traces land under this project name. Dev = Ai-Poc-Dev, prod = Ai-Poc-Prod.
LANGCHAIN_PROJECT=Ai-Poc-Dev

# Same LangSmith key — used by LangGraph self-hosted lite for licensing.
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxx

# --- Server auth (production) ---
# The X-Api-Key value enforced by Caddy on the deployed server (see docs/3).
# Not used by the app itself; it lives in the server's Caddyfile.
# Generate with: openssl rand -hex 24
